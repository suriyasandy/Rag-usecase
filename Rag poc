# ══════════════════════════════════════════════════════════════════════════
class InternalEmbeddings:
    """LangChain-compatible embeddings using your internal embed endpoint."""

    def __init__(self, jm: JWTManager):
        self.jm = jm

    def _client(self): return get_embed_client(self.jm.token)

    def embed_documents(self, texts: List[str]) -> List[List[float]]:
        resp = self._client().embeddings.create(input=texts, model=EMBED_MODEL)
        return [item.embedding for item in resp.data]

    def embed_query(self, text: str) -> List[float]:
        return self.embed_documents([text])[0]


# ══════════════════════════════════════════════════════════════════════════
#  FAISS
# ══════════════════════════════════════════════════════════════════════════
def build_or_load_faiss(docs: List[Document], jm: JWTManager) -> FAISS:
    emb = InternalEmbeddings(jm)
    if Path(FAISS_INDEX_PATH).exists():
        return FAISS.load_local(FAISS_INDEX_PATH, emb,
                                allow_dangerous_deserialization=True)
    chunks = RecursiveCharacterTextSplitter(
        chunk_size=400, chunk_overlap=40
    ).split_documents(docs)
    vs = FAISS.from_documents(chunks, emb)
    vs.save_local(FAISS_INDEX_PATH)
    return vs


def rebuild_faiss(docs: List[Document], jm: JWTManager) -> FAISS:
    import shutil
    if Path(FAISS_INDEX_PATH).exists(): shutil.rmtree(FAISS_INDEX_PATH)
    return build_or_load_faiss(docs, jm)


