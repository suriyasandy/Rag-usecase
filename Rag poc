                f"{'✅ Yes — apply fix then re-run the bot manually' if rerun else '❌ No — do NOT rerun; escalate if fix does not work'}"
            )
            if l1.get("sop_reference"):
                st.caption(f"SOP: `{l1['sop_reference']}`")
            st.markdown("</div>", unsafe_allow_html=True)

    # ── L2 Template ───────────────────────────────────────────────────────
    if decision == "ESCALATE" or "_raw" in l1:
        with t1:
            st.markdown('<div class="l2box">', unsafe_allow_html=True)
            st.markdown("### 📋 Pre-filled L2 Escalation Template")
            st.caption("Review · edit · add comments · then submit")
            st.markdown("</div>", unsafe_allow_html=True)

            l2 = st.session_state.l2_filled or {}

            if "_raw" in l2:
                # RAG returned free-text, not JSON — show in editable box
                st.markdown("**RAG response (edit below):**")
                st.text_area("L2 Content", value=l2["_raw"], height=300, key="l2_raw")
            else:
                # Render standard template fields
                l2_fields = [
                    ("Error Summary",        "mandatory"),
                    ("Affected Module",      "mandatory"),
                    ("Error Classification", "mandatory"),
                    ("Priority",             "mandatory"),
                    ("Root Cause",           "mandatory"),
                    ("L1 Fix Attempted",     "mandatory"),
                    ("Stack Trace Summary",  "mandatory"),
                    ("SOP Reference",        "optional"),
                    ("Run ID",               "optional"),
                    ("Bot Version",          "optional"),
                ]
                filled = {}
                for fname, req in l2_fields:
                    label = f"{fname} {'*(required)*' if req == 'mandatory' else ''}"
                    filled[fname] = st.text_area(
                        label,
                        value=l2.get(fname, ""),
                        height=64,
                        key=f"f_{fname}",
                    )

                st.markdown("---")
                extra = st.text_area(
                    "Additional Comments *(optional)*",
                    height=72, key="extra_cmts",
                )
                if extra:
                    filled["User Comments"] = extra

                cs, cc = st.columns(2)
                if cs.button("🚀 Submit to L2", type="primary", use_container_width=True):
                    st.success("✅ Submitted — wire your Jira agent here.")
                if cc.button("📋 Export JSON", use_container_width=True):
                    st.code(json.dumps(filled, indent=2), language="json")

        with t2:
            if "_raw" in l1:
                st.markdown('<div class="warnbox">', unsafe_allow_html=True)
                st.markdown(
                    "The RAG API returned a non-JSON response for L1. "
                    "This usually means the knowledge base didn't find a structured SOP match. "
                    "Escalating to L2."
                )
                st.markdown("</div>", unsafe_allow_html=True)
                st.markdown("**Raw L1 response from RAG:**")
                st.text(l1["_raw"])
            else:
                reason = l1.get("escalation_reason", "")
                if reason:
                    st.warning(f"**Escalation reason:** {reason}")
                if l1.get("root_cause"):
                    st.info(f"**Root cause:** {l1['root_cause']}")

    # ── RAG Debug tab ─────────────────────────────────────────────────────
    debug_tab = t2 if decision == "L1_FIX_AVAILABLE" and "_raw" not in l1 else t3
    with debug_tab:
        st.markdown(f"**RAG endpoint called:** `{_rag_url()}`")
        st.markdown(f"**History turns sent:** `{len(st.session_state.rag_history)}`")
        if st.session_state.raw_rag_resp:
            st.markdown("**Full RAG API response:**")
            st.json(st.session_state.raw_rag_resp)

    # ── Raw JSON tab ──────────────────────────────────────────────────────
    raw_tab = t3 if decision == "L1_FIX_AVAILABLE" and "_raw" not in l1 else t4
    with raw_tab:
        st.markdown("**L1 parsed result:**");  st.json(l1)
        if st.session_state.l2_filled:
            st.markdown("**L2 pre-fill:**");   st.json(st.session_state.l2_filled)
