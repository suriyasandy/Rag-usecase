    # Step 1: Load SOP CSV
    docs = load_sop_csv(CONFIG["sop_csv_path"])
    if not docs:
        print("❌ No documents loaded. Check your CSV path and column names.")
        return

    # Step 2: Build / load FAISS index
    vs = get_or_build_index(docs)

    # Step 3–5: Run each test query through the full pipeline
    print(f"\n🔍 Running {len(TEST_QUERIES)} test queries...\n")

    for i, query in enumerate(TEST_QUERIES, 1):
        print(f"\n{'━'*70}")
        print(f"  Test {i} of {len(TEST_QUERIES)}")
        print(f"{'━'*70}")

        # Retrieve
        retrieved = retrieve(vs, query, top_k=3)

        # Call LLM
        print(f"  ⏳ Calling GPT-4.1...")
        llm_resp = call_llm(query, retrieved)

        # Print
        print_result(query, retrieved, llm_resp)

    print("\n✅ PoC complete. All queries processed.\n")
    print("💡 Next steps:")
    print("   1. Replace TEST_QUERIES with real Genie Bot error logs")
    print("   2. Update CSV_COLUMN_MAP to match your actual CSV headers")
    print("   3. Add more SOP rows to improve retrieval accuracy")
    print("   4. Tune similarity thresholds (currently 0.75 = match)")
    print()


if __name__ == "__main__":
    main()
