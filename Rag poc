def load_data() -> Tuple[List[Document], List[dict], List[str]]:
    created = []
    if not Path(SOP_CSV_PATH).exists():
        _make_sample_sop();      created.append(f"Sample SOP created → {SOP_CSV_PATH}")
    if not Path(TEMPLATE_CSV_PATH).exists():
        _make_sample_template(); created.append(f"Sample template created → {TEMPLATE_CSV_PATH}")

    sop_docs = []
    with open(SOP_CSV_PATH, newline="", encoding="utf-8") as f:
        for i, row in enumerate(csv.DictReader(f)):
            parts = []
            for field, col in SOP_COLS.items():
                val = row.get(col, "").strip()
                if val: parts.append(f"{field.replace('_',' ').title()}: {val}")
            if not parts:
                parts = [f"{k}: {v}" for k, v in row.items() if v.strip()]
            sop_docs.append(Document(
                page_content="\n".join(parts),
                metadata={"source":"sop",
                          "sop_ref":    row.get(SOP_COLS["sop_ref"],    f"ROW-{i+1}"),
                          "module":     row.get(SOP_COLS["module"],     ""),
                          "rerun_safe": row.get(SOP_COLS["rerun_safe"], "Unknown"),
                          "fix_steps":  row.get(SOP_COLS["fix_steps"],  "")}))

    template_fields = []
    with open(TEMPLATE_CSV_PATH, newline="", encoding="utf-8") as f:
        for row in csv.DictReader(f):
            template_fields.append({
                "field":       row.get(TMPL_COLS["field_name"],  ""),
                "description": row.get(TMPL_COLS["description"], ""),
                "example":     row.get(TMPL_COLS["example"],     ""),
                "mandatory":   row.get(TMPL_COLS["mandatory"],   "No"),
            })
    return sop_docs, template_fields, created


