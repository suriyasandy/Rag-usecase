    Sync OpenAI client for embedding endpoint.
    Same SDK pattern, different base_url + model.
    JWT injected per-call so it stays fresh (recreated each time).
    """
    return OpenAI(
        api_key="custom",
        base_url=EMBED_BASE_URL,
        default_headers={**get_default_headers(), **get_extra_headers(jwt)},
    )


# ══════════════════════════════════════════════════════════════════════════
#  extract_message_content — exact replica of your function
# ══════════════════════════════════════════════════════════════════════════
def extract_message_content(message_content: Any) -> str:
    if isinstance(message_content, str):
        return message_content
    if isinstance(message_content, list):
        parts = []
        for item in message_content:
            if isinstance(item, dict):
                if item.get("type") == "text" and item.get("text"):
                    parts.append(item["text"])
                elif item.get("type") == "output" and item.get("output"):
                    parts.append(item["output"])
            else:
                itype = getattr(item, "type", None)
                itext = getattr(item, "text", None) or getattr(item, "output", None)
                if itype in ("text", "output") and itext:
                    parts.append(itext)
        return "".join(parts)
    if hasattr(message_content, "content"):
        c = message_content.content
        if isinstance(c, str):  return c
        if isinstance(c, list): return extract_message_content(c)
    return ""


# ══════════════════════════════════════════════════════════════════════════
#  JWT AUTO-REFRESH — background thread, 30 s TTL
# ══════════════════════════════════════════════════════════════════════════
class JWTManager:
    def __init__(self):
        self._token       = ""
        self._expires_at  = 0.0
        self._lock        = threading.Lock()
        self._thread      = None
        self._running     = False
        self.last_refresh = "Never"
        self.last_error   = ""
        self.refresh_count = 0

    @property
    def token(self):
        with self._lock: return self._token

    @property
    def is_valid(self):
        with self._lock:
            return bool(self._token) and time.time() < self._expires_at

    @property
    def seconds_remaining(self):
        with self._lock: return max(0, int(self._expires_at - time.time()))

    def start(self):
        self._fetch()
        self._running = True
        self._thread  = threading.Thread(target=self._loop, daemon=True)
        self._thread.start()

    def stop(self):    self._running = False
    def refresh(self): self._fetch()

    def _loop(self):
        while self._running:
            time.sleep(max(TOKEN_TTL - 5, 5))
            self._fetch()

    def _fetch(self):
        try:
            tok = get_token()
            with self._lock:
                self._token       = tok
                self._expires_at  = time.time() + TOKEN_TTL
                self.last_refresh = datetime.now(timezone.utc).strftime("%H:%M:%S UTC")
                self.last_error   = ""
                self.refresh_count += 1
        except Exception as e:
            with self._lock: self.last_error = str(e)


# ══════════════════════════════════════════════════════════════════════════
#  LLM CALL — mirrors your exact call pattern
# ══════════════════════════════════════════════════════════════════════════
async def _llm_async(messages: list, jwt: str, max_tokens: int = 2000) -> str:
    extra_headers = get_extra_headers(jwt)      # fresh JWT per call
    client        = get_llm_client()            # singleton

    result = await client.chat.completions.create(
        model=LLM_MODEL,
        messages=messages,
        max_completion_tokens=max_tokens,
        extra_headers=extra_headers,
        user="",
        temperature=LLM_TEMP,
    )
    return extract_message_content(result.choices[0].message.content)


def call_llm(messages: list, jwt: str, max_tokens: int = 2000) -> str:
    return asyncio.run(_llm_async(messages, jwt, max_tokens))


