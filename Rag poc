# STEP 2 — Build FAISS index (or load existing)
# ══════════════════════════════════════════════════════════════════════════
def get_or_build_index(docs: list[Document]) -> FAISS:
    """
    If FAISS index already exists on disk, load it.
    Otherwise embed all docs and build fresh index.
    """
    embeddings = AzureOpenAIEmbeddings(
        azure_deployment=CONFIG["embed_deployment"],
        azure_endpoint=CONFIG["azure_endpoint"],
        api_key=CONFIG["azure_api_key"],
        api_version=CONFIG["azure_api_version"],
    )

    faiss_path = CONFIG["faiss_path"]

    if Path(faiss_path).exists():
        print(f"📦 Loading existing FAISS index from {faiss_path}...")
        vs = FAISS.load_local(faiss_path, embeddings, allow_dangerous_deserialization=True)
        print(f"✅ Index loaded\n")
        return vs

    print(f"🔨 Building new FAISS index (embedding {len(docs)} documents)...")
    print(f"   Model: {CONFIG['embed_deployment']}")

    # Chunk documents for better retrieval
    splitter = RecursiveCharacterTextSplitter(chunk_size=400, chunk_overlap=40)
    chunks   = splitter.split_documents(docs)
    print(f"   Chunked into {len(chunks)} segments")

    vs = FAISS.from_documents(chunks, embeddings)
    vs.save_local(faiss_path)
    print(f"✅ FAISS index built and saved to {faiss_path}\n")
    return vs


# ══════════════════════════════════════════════════════════════════════════
# STEP 3 — Retrieve similar SOPs for a query
# ══════════════════════════════════════════════════════════════════════════
def retrieve(vs: FAISS, query: str, top_k: int = 3) -> list[tuple]:
    """
    Embed query and find top-k most similar SOP entries.
    Returns list of (Document, similarity_score) tuples.
    """
    results = vs.similarity_search_with_relevance_scores(query, k=top_k)
    return results


# ══════════════════════════════════════════════════════════════════════════
# STEP 4 — Call GPT-4.1 with retrieved context
# ══════════════════════════════════════════════════════════════════════════
SYSTEM_PROMPT = """You are a deterministic L1 triage agent for Genie Bot production support.
Analyse the user's error against the retrieved SOP entries and respond with structured JSON.

RULES:
- Temperature=0. Only use information from the retrieved SOPs. Never invent fixes.
- plain_english_fix must be written for a non-technical business user. No jargon. No code.
- rerun_safe=true ONLY if the SOP explicitly says the fix is safe to rerun.
- If no good match is found, set decision to ESCALATE.

Respond ONLY with valid JSON:
{
  "decision": "L1_FIX_AVAILABLE" or "ESCALATE",
  "confidence": "HIGH" or "MEDIUM" or "LOW",
  "root_cause": "plain English explanation of what went wrong",
  "plain_english_fix": "numbered steps a non-technical user can follow",
  "rerun_safe": true or false,
  "sop_reference": "SOP ref if found, else null",
  "reasoning": "brief explanation of why this decision was made"
}"""


def call_llm(query: str, retrieved_docs: list[tuple]) -> dict:
    """
    Send query + retrieved SOP context to GPT-4.1.
    Returns parsed JSON response.
    """
    llm = AzureChatOpenAI(
        azure_deployment=CONFIG["llm_deployment"],
        azure_endpoint=CONFIG["azure_endpoint"],
        api_key=CONFIG["azure_api_key"],
        api_version=CONFIG["azure_api_version"],
        temperature=0.0,     # Always 0 — deterministic
        max_tokens=800,
    )

    # Build context string from retrieved SOPs
    context_parts = []
    for i, (doc, score) in enumerate(retrieved_docs, 1):
        context_parts.append(
            f"--- SOP Match {i} (similarity score: {score:.3f}) ---\n"
            f"{doc.page_content}"
        )
    context_str = "\n\n".join(context_parts)

    user_message = (
        f"ERROR LOG / QUERY:\n{query}\n\n"
        f"RETRIEVED SOP ENTRIES:\n{context_str}\n\n"
        f"Provide your JSON diagnosis now."
    )

    response = llm.invoke([
        ("system", SYSTEM_PROMPT),
        ("human",  user_message),
    ])

    raw = response.content.strip()

    # Parse JSON — handle cases where model adds markdown fences
    clean = raw.lstrip("```json").lstrip("```").rstrip("```").strip()
    try:
        return json.loads(clean)
    except json.JSONDecodeError:
        return {
            "decision":         "ESCALATE",
            "confidence":       "LOW",
            "root_cause":       "Could not parse LLM response",
            "plain_english_fix":"Please escalate to the support team.",
            "rerun_safe":       False,
            "sop_reference":    None,
            "reasoning":        f"JSON parse failed. Raw response: {raw[:200]}",
        }


# ══════════════════════════════════════════════════════════════════════════
# STEP 5 — Pretty-print the full result
# ══════════════════════════════════════════════════════════════════════════
def print_result(query: str, retrieved: list[tuple], llm_response: dict):
    """Print a clean, readable summary of the full RAG pipeline result."""
    w = 70
    print("=" * w)
    print("QUERY:")
    print(textwrap.fill(query, width=w, initial_indent="  "))
    print()

    print("── RETRIEVED SOP MATCHES ──────────────────────────────────────")
    for i, (doc, score) in enumerate(retrieved, 1):
        colour = "✅" if score >= 0.75 else "🟡" if score >= 0.50 else "❌"
        print(f"  {colour} Match {i}: score={score:.4f}  ref={doc.metadata.get('sop_ref','?')}")
        # Show first line of the SOP content
        first_line = doc.page_content.split("\n")[0]
        print(f"     {first_line[:80]}")
    print()

    print("── LLM RESPONSE (GPT-4.1) ─────────────────────────────────────")
    decision = llm_response.get("decision", "?")
    conf     = llm_response.get("confidence", "?")
    icon     = "✅" if decision == "L1_FIX_AVAILABLE" else "🔴"
    print(f"  {icon} Decision:    {decision}  ({conf} confidence)")
    print()

    root = llm_response.get("root_cause", "")
    if root:
        print(f"  Root Cause:")
        print(textwrap.fill(root, width=w, initial_indent="    "))
        print()

    fix = llm_response.get("plain_english_fix", "")
    if fix:
        print(f"  Fix (plain English for user):")
        for line in fix.split("\n"):
            print(f"    {line}")
        print()

    print(f"  Rerun Safe:   {'Yes ✅' if llm_response.get('rerun_safe') else 'No ❌ — manual rerun only'}")
    print(f"  SOP Ref:      {llm_response.get('sop_reference') or 'None found'}")

    reasoning = llm_response.get("reasoning", "")
    if reasoning:
        print(f"\n  Reasoning:    {reasoning[:120]}")

    print("=" * w)
    print()


