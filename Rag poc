def _parse_json(raw: str) -> dict:
    clean = raw.strip().lstrip("```json").lstrip("```").rstrip("```").strip()
    try:    return json.loads(clean)
    except: return {"_parse_error": raw[:500]}


def run_l1(log_text: str, retrieved: list, jwt: str) -> dict:
    ctx = "\n\n".join(
        f"--- SOP {i} (score={s:.3f}, ref={d.metadata.get('sop_ref','?')}) ---\n{d.page_content}"
        for i,(d,s) in enumerate(retrieved, 1))
    return _parse_json(call_llm([
        {"role":"system","content":L1_SYS},
        {"role":"user",  "content":f"ERROR LOG:\n{log_text[:2000]}\n\nSOPs:\n{ctx}\n\nJSON:"},
    ], jwt, max_tokens=900))


def run_l2(log_text: str, tmpl_fields: list, l1: dict, jwt: str) -> dict:
    fdesc = "\n".join(
        f"- {f['field']} ({'mandatory' if f['mandatory']=='Yes' else 'optional'}): "
        f"{f['description']}. e.g. {f['example']}" for f in tmpl_fields)
    return _parse_json(call_llm([
        {"role":"system","content":L2_SYS},
        {"role":"user",  "content":
            f"ERROR LOG:\n{log_text[:1500]}\n\nL1:\n{json.dumps(l1,indent=2)}\n\n"
            f"FIELDS:\n{fdesc}\n\nJSON:"},
    ], jwt, max_tokens=1200))


