# STEP 1 — Load and parse SOP CSV
# ══════════════════════════════════════════════════════════════════════════
def load_sop_csv(csv_path: str) -> list[Document]:
    """
    Load SOP CSV into LangChain Documents.
    Each row becomes one document combining all relevant fields.
    """
    path = Path(csv_path)
    if not path.exists():
        print(f"\n⚠  CSV not found at: {csv_path}")
        print("   Creating a sample CSV so you can see the expected format...\n")
        _create_sample_csv(csv_path)

    docs = []
    with open(csv_path, newline="", encoding="utf-8") as f:
        reader = csv.DictReader(f)
        headers = reader.fieldnames or []

        print(f"📄 CSV columns detected: {headers}")

        for i, row in enumerate(reader):
            # Build document text from available columns
            # Tries your mapped column names, falls back gracefully
            parts = []
            for field, col in CSV_COLUMN_MAP.items():
                val = row.get(col, "").strip()
                if val:
                    parts.append(f"{field.replace('_', ' ').title()}: {val}")

            # If mapping didn't work, just use all columns
            if not parts:
                parts = [f"{k}: {v}" for k, v in row.items() if v.strip()]

            content = "\n".join(parts)
            if content.strip():
                docs.append(Document(
                    page_content=content,
                    metadata={
                        "row_num":      i + 1,
                        "source":       "sop_csv",
                        "sop_ref":      row.get(CSV_COLUMN_MAP["sop_ref"], f"ROW-{i+1}"),
                        "module":       row.get(CSV_COLUMN_MAP["module"], ""),
                        "rerun_safe":   row.get(CSV_COLUMN_MAP["rerun_safe"], "Unknown"),
                    }
                ))

    print(f"✅ Loaded {len(docs)} SOP records from CSV\n")
    return docs


