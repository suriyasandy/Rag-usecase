def _rag_url() -> str:
    """Build: {RAG_BASE_URL}/generation/{usecase_id}/{pipeline_id}"""
    base = RAG_BASE_URL.rstrip("/")
    return f"{base}/generation/{RAG_USECASE}/{RAG_PIPELINE}"


def call_rag(
    query: str,
    jwt: str,
    history: list[dict] | None = None,
) -> dict:
    """
    POST /generation/{usecase_id}/{pipeline_id}
    Header : AMToken = <jwt>
    Body   : { "query": "...", "history": [...] }

    Returns the full response JSON.
    The answer text is extracted from common response field names.
    """
    url     = _rag_url()
    headers = {
        "Content-Type": "application/json",
        "Accept":       "application/json",
        "AMToken":      jwt,                    # ← your header key from the spec
    }
    body = {
        "query":   query,
        "history": history or [],
    }

    resp = requests.post(
        url, headers=headers, json=body,
        timeout=RAG_TIMEOUT, verify=VERIFY_TLS,
    )
    resp.raise_for_status()
    return resp.json()


def extract_answer(rag_response: dict) -> str:
    """
    Extract the text answer from the RAG response.
    Tries common field names — update if your response shape differs.
    """
    for key in ("answer", "response", "result", "output", "text", "content"):
        val = rag_response.get(key)
        if val and isinstance(val, str):
            return val
    # If nested under 'data' or 'choices'
    if "data" in rag_response and isinstance(rag_response["data"], dict):
        return extract_answer(rag_response["data"])
    if "choices" in rag_response:
        try:
            return rag_response["choices"][0]["message"]["content"]
        except Exception:
            pass
    # Fallback — return full JSON so nothing is silently lost
    return json.dumps(rag_response, indent=2)


def _parse_json_from_answer(answer: str) -> dict:
    """Parse JSON from LLM answer text. Handles markdown fences."""
    clean = answer.strip().lstrip("```json").lstrip("```").rstrip("```").strip()
    try:
        return json.loads(clean)
    except json.JSONDecodeError:
        return {"_raw": answer}


# ══════════════════════════════════════════════════════════════════════════
#  L1 TRIAGE via RAG API
# ══════════════════════════════════════════════════════════════════════════

def run_l1_rag(log_text: str, jwt: str,
               history: list[dict]) -> tuple[dict, dict, list[dict]]:
    """
    Send log to RAG endpoint with L1 instruction prepended.
    Returns (l1_parsed_dict, raw_rag_response, updated_history).
    """
    query = L1_INSTRUCTION + log_text[:2500]

    raw_resp = call_rag(query, jwt, history)
    answer   = extract_answer(raw_resp)
    l1       = _parse_json_from_answer(answer)

    # Append to history for potential follow-up L2 call
    updated_history = history + [
        {"question": query, "answer": answer}
    ]
    return l1, raw_resp, updated_history


# ══════════════════════════════════════════════════════════════════════════
#  L2 TEMPLATE PRE-FILL via RAG API
# ══════════════════════════════════════════════════════════════════════════

def run_l2_rag(log_text: str, l1_result: dict,
               jwt: str, history: list[dict]) -> tuple[dict, list[dict]]:
    """
    Send log + L1 diagnosis to RAG endpoint for L2 template pre-fill.
    History carries the L1 context so RAG has full conversation.
    Returns (l2_filled_dict, updated_history).
    """
    query = (
        L2_INSTRUCTION
        + f"\n\nERROR LOG:\n{log_text[:1500]}"
        + f"\n\nL1 DIAGNOSIS:\n{json.dumps(l1_result, indent=2)}"
    )

    raw_resp = call_rag(query, jwt, history)
    answer   = extract_answer(raw_resp)
    l2       = _parse_json_from_answer(answer)

    updated_history = history + [
        {"question": query, "answer": answer}
    ]
    return l2, updated_history


