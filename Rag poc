    c_sub, c_exp = st.columns(2)
    if c_sub.button("🚀 Submit to L2 Support Team", type="primary", use_container_width=True):
        st.success("✅ Ticket submitted to L2 queue. Wire your Jira agent here.")
    if c_exp.button("📋 Export as JSON", use_container_width=True):
        st.code(json.dumps(filled, indent=2), language="json")

    st.markdown("---")
    # Debug — ONLY data.content.content
    with st.expander("🔧 RAG response — data.content.content (L2)", expanded=False):
        try:
            st.text(st.session_state.l2_raw_resp["data"]["content"]["content"])
        except Exception:
            st.json(st.session_state.l2_raw_resp)
