def build_l2_query(log, l1_answer, template_fields=""):
    if template_fields:
        section = (
            "Fill EXACTLY these fields (do not add or remove any, "
            "output as a markdown table with columns Field | Value | Notes):\n"
            + template_fields + "\n\n"
        )
    else:
        section = (
            "Include: error summary, affected module, classification, priority, "
            "root cause, what was tried, stack trace summary, SOP reference, run ID. "
            "Output as a markdown table: Field | Value | Notes.\n\n"
        )
    return L2_QUERY.format(
        template_section=section,
        l1_answer=l1_answer,
        log=log[:1500],
    )


