def fix_newlines(text):
    """RAG returns literal backslash-n. Convert to real newlines for markdown."""
    return text.replace("\\n", "\n").replace("\\t", "\t")


def extract_content(raw):
    """Pull answer from data.content.content — your confirmed response path."""
    try:
        return raw["data"]["content"]["content"]
    except (KeyError, TypeError):
        for key in ("answer", "response", "result", "output", "text"):
            val = raw.get(key)
            if val and isinstance(val, str):
                return val
        return json.dumps(raw, indent=2)


def load_template_csv(uploaded_file):
    """
    Parse template CSV -> list of dicts: {field, desc, mandatory}
    Accepts column names: field_name / Field / field,
                          description / Description / desc,
                          mandatory / Mandatory / required
    """
    try:
        text    = uploaded_file.read().decode("utf-8", errors="replace")
        reader  = csv.DictReader(io.StringIO(text))
        rows    = list(reader)
        if not rows:
            return []
        headers = list(rows[0].keys())
        result  = []
        for row in rows:
            name = (row.get("field_name") or row.get("Field Name") or
                    row.get("field")      or row.get("Field")      or
                    row.get(headers[0], "")).strip()
            desc = (row.get("description") or row.get("Description") or
                    row.get("desc")        or
                    (row.get(headers[1], "") if len(headers) > 1 else "")).strip()
            mval = (row.get("mandatory") or row.get("Mandatory") or
                    row.get("required")  or row.get("Required")  or "").strip()
            mand = mval.lower() in ("yes", "true", "y", "1")
            if name:
                result.append({"field": name, "desc": desc, "mandatory": mand})
        return result
    except Exception as e:
        st.error(f"Could not parse template CSV: {e}")
        return []


def parse_markdown_table(text):
    """
    Parse a markdown table into {field: {value, note}} dict.
    Handles: | Section | Field | Value | Notes |
             | Field | Value |  (simple 2-col)
    """
    result, header = {}, []
    for line in [l.strip() for l in text.splitlines() if l.strip()]:
        if not line.startswith("|"):
            continue
        cells = [c.strip() for c in line.strip("|").split("|")]
        cells = [c for c in cells if c]
        if not cells:
            continue
        if all(c.replace("-","").replace(":","").replace(" ","") == "" for c in cells):
            continue   # separator row
        if not header:
            header = cells
            continue
        if len(cells) < 2:
            continue
        fi = next((i for i,h in enumerate(header) if "field" in h.lower()), 1)
        vi = next((i for i,h in enumerate(header) if "value" in h.lower()), min(2, len(cells)-1))
        ni = next((i for i,h in enumerate(header) if "note"  in h.lower()), -1)
        if fi < len(cells) and vi < len(cells):
            f = cells[fi]
            if f and f not in ("Field","field","—","-",""):
                result[f] = {
                    "value": cells[vi],
                    "note":  cells[ni] if 0 <= ni < len(cells) else "",
                }
    return result


def fuzzy_match(field_name, parsed):
    """Find best value for a field name — case-insensitive contains match."""
    fn = field_name.lower().strip()
    for k, v in parsed.items():
        kl = k.lower()
        if fn in kl or kl in fn:
            return v.get("value", "")
    return ""


