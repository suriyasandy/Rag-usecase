#  TEMPLATE CSV LOADER
# ══════════════════════════════════════════════════════════════════════════
def load_template_csv(uploaded_file) -> str:
    """
    Load your template CSV and return a formatted string of field names + descriptions.
    This is injected into the L2 RAG query so the model fills YOUR exact fields.
    Expected CSV columns: field_name, description, example, mandatory
    (column names are flexible — any two-column CSV works)
    """
    try:
        text   = uploaded_file.read().decode("utf-8", errors="replace")
        reader = csv.DictReader(io.StringIO(text))
        rows   = list(reader)
        if not rows:
            return ""
        headers = list(rows[0].keys())
        lines   = []
        for row in rows:
            # Try common column name patterns
            name  = (row.get("field_name") or row.get("Field Name") or
                     row.get("field") or row.get("Field") or row.get(headers[0], ""))
            desc  = (row.get("description") or row.get("Description") or
                     row.get("desc") or (row.get(headers[1], "") if len(headers) > 1 else ""))
            mand  = (row.get("mandatory") or row.get("Mandatory") or
                     row.get("required") or row.get("Required") or "")
            if name.strip():
                suffix = " (mandatory)" if str(mand).strip().lower() in ("yes","true","y","1") else ""
                lines.append(f"- {name.strip()}{suffix}: {desc.strip()}" if desc.strip()
                             else f"- {name.strip()}{suffix}")
        return "\n".join(lines)
    except Exception as e:
        return f"(Could not parse template CSV: {e})"


def fix_newlines(text: str) -> str:
    """
    RAG returns escaped \n as literal backslash-n.
    Convert to real newlines so markdown tables render correctly.
    """
    return text.replace("\\n", "\n").replace("\\t", "\t")


