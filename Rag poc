st.title("🤖 Genie Bot AI Support Copilot")
st.caption("Paste or upload an error log → L1 fix (if SOP match) or pre-filled L2 template")

if not st.session_state.data_loaded:
    for num, (flag, label) in {
        "1":("jwt_started",  "Start JWT manager in the sidebar"),
        "2":("data_loaded",  "Load SOP data from the sidebar"),
        "3":(None,           "Paste a log and click Diagnose"),
    }.items():
        done = flag and st.session_state.get(flag)
        st.markdown(f"{'✅' if done else '○'} **Step {num}:** {label}")

# Input
tab_paste, tab_upload = st.tabs(["📋 Paste Log", "📁 Upload Log File"])
log_text = ""

with tab_paste:
    log_text = st.text_area("Paste Genie Bot error log", height=220,
        placeholder=(
            "[2026-05-27 09:14:32 UTC] RUN_ID=GBT-20260527-0042 ENV=PROD\n"
            "[ERROR] Module: TradeDataExtractor | Exit: FAILED\n"
            "[ERROR] System.NullReferenceException: Object reference not set\n"
            "   at GeniBot.Core.DataExtractor.Execute() line 142\n"
            "[INPUT] Entity=GBCIB | ReportDate=2026-05-27"),
        key="log_paste")

with tab_upload:
    uploaded = st.file_uploader("Upload .log / .txt", type=["log","txt"])
    if uploaded:
        log_text = uploaded.read().decode("utf-8", errors="replace")
        st.text_area("Preview", value=log_text[:600]+("…" if len(log_text)>600 else ""),
                     height=140, disabled=True)

# Buttons
ready = st.session_state.data_loaded and st.session_state.jwt_started and jm.is_valid
col_btn, col_clr = st.columns([4, 1])
diag_btn = col_btn.button("🔍 Diagnose Issue", type="primary",
                           use_container_width=True, disabled=not ready)
if not ready:
    hint = ("Start JWT first" if not st.session_state.jwt_started
            else "Load SOP data first" if not st.session_state.data_loaded
            else "JWT expired — force refresh")
    col_btn.caption(f"⚠ {hint}")
if col_clr.button("🗑 Clear", use_container_width=True):
    st.session_state.result = st.session_state.l2_filled = None
    st.rerun()

# Run
if diag_btn:
    if not log_text.strip():
        st.warning("Please paste or upload an error log first.")
    else:
        jwt = jm.token
        vs  = st.session_state.faiss_index

        with st.spinner("🔍 Searching local FAISS index…"):
            retrieved = vs.similarity_search_with_relevance_scores(
                log_text[:1500], k=st.session_state.top_k)
        top_score = retrieved[0][1] if retrieved else 0.0

        with st.spinner(f"🤖 Calling LLM ({LLM_MODEL})…"):
            l1 = run_l1(log_text, retrieved, jwt)

        if top_score < st.session_state.sim_threshold:
            l1["decision"] = "ESCALATE"
            l1["escalation_reason"] = (
                l1.get("escalation_reason") or
                f"Top score {top_score:.4f} < threshold {st.session_state.sim_threshold}")

        l2 = None
        if l1.get("decision") == "ESCALATE":
            with st.spinner("📋 Pre-filling L2 template…"):
                l2 = run_l2(log_text, st.session_state.template_fields, l1, jwt)

        st.session_state.result   = {"l1":l1,"retrieved":retrieved,"top_score":top_score}
        st.session_state.l2_filled = l2


# Results
if st.session_state.result:
    r         = st.session_state.result
    l1        = r["l1"]
    retrieved = r["retrieved"]
    top_score = r["top_score"]
    decision  = l1.get("decision","ESCALATE")
    conf      = l1.get("confidence","LOW")
    ci        = {"HIGH":"🟢","MEDIUM":"🟡","LOW":"🔴"}.get(conf,"⚪")

    st.markdown("---")
    c1,c2,c3,c4 = st.columns(4)
    c1.metric("Decision",      "✅ L1 Fix" if decision=="L1_FIX_AVAILABLE" else "🔴 Escalate")
    c2.metric("Confidence",    f"{ci} {conf}")
    c3.metric("Top Similarity",f"{top_score:.4f}")
    c4.metric("SOP Match",     l1.get("sop_reference") or "None")
    st.markdown("---")

    tabs = (st.tabs(["✅ L1 Fix","🔍 Retrieved SOPs","🔧 Raw JSON"])
            if decision=="L1_FIX_AVAILABLE"
            else st.tabs(["📋 L2 Template","❌ Why Escalated","🔍 Retrieved SOPs","🔧 Raw JSON"]))

    # L1 Fix
    if decision == "L1_FIX_AVAILABLE":
        with tabs[0]:
            st.markdown('<div class="l1box">', unsafe_allow_html=True)
            st.markdown(f"### ✅ L1 Fix Found — **{conf}** confidence")
            if l1.get("root_cause"):
                st.markdown("**🔍 Root Cause**"); st.info(l1["root_cause"])
            if l1.get("plain_english_fix"):
                st.markdown("**🔧 Steps (plain English)**")
                for line in l1["plain_english_fix"].split("\n"):
                    if line.strip(): st.write(line)
            rerun = l1.get("rerun_safe", False)
            st.markdown(f"**Rerun Safe:** {'✅ Yes — apply fix then re-run manually' if rerun else '❌ No — do NOT rerun'}")
            if l1.get("sop_reference"): st.caption(f"SOP: `{l1['sop_reference']}`")
            if l1.get("citations"):     st.caption(f"Based on: {', '.join(l1['citations'])}")
            st.markdown("</div>", unsafe_allow_html=True)
            if l1.get("technical_fix"):
                with st.expander("🛠 Technical details (L2 reference)"):
                    st.text(l1["technical_fix"])

    # L2 Template
    if decision == "ESCALATE":
        with tabs[0]:
            st.markdown('<div class="l2box">', unsafe_allow_html=True)
            st.markdown("### 📋 Pre-filled L2 Escalation Template")
            st.caption("Review · edit · add comments · then submit")
            st.markdown("</div>", unsafe_allow_html=True)
            l2 = st.session_state.l2_filled or {}
            if "_parse_error" in l2:
                st.error("Template parse failed"); st.text(l2["_parse_error"])
            else:
                filled = {}
                for fd in st.session_state.template_fields:
                    fn = fd["field"]
                    filled[fn] = st.text_area(
                        f"{fn} {'*(required)*' if fd['mandatory']=='Yes' else ''}",
                        value=l2.get(fn,""), height=68, key=f"f_{fn}",
                        help=f"{fd['description']}  |  e.g. {fd['example']}")
                st.markdown("---")
                extra = st.text_area("Additional Comments *(optional)*", height=72, key="extra")
                if extra: filled["User Comments"] = extra
                cs, cc = st.columns(2)
                if cs.button("🚀 Submit to L2", type="primary", use_container_width=True):
                    st.success("✅ Submitted — wire your Jira agent here.")
                if cc.button("📋 Export JSON", use_container_width=True):
                    st.code(json.dumps(filled, indent=2), language="json")

        with tabs[1]:
            if top_score < st.session_state.sim_threshold:
                st.markdown('<div class="warnbox">', unsafe_allow_html=True)
                st.markdown(f"No strong SOP match. Top score `{top_score:.4f}` < threshold `{st.session_state.sim_threshold}`.")
                st.markdown("</div>", unsafe_allow_html=True)
            reason = l1.get("escalation_reason")
            if reason: st.warning(f"Escalation reason: {reason}")
            if l1.get("root_cause"): st.info(l1["root_cause"])

    # Retrieved SOPs
    with tabs[1 if decision=="L1_FIX_AVAILABLE" else 2]:
        st.markdown(f"Top **{len(retrieved)}** SOPs  |  threshold: `{st.session_state.sim_threshold}`  |  embed: `{EMBED_BASE_URL}`")
        for i,(doc,score) in enumerate(retrieved,1):
            icon = ("🟢" if score>=st.session_state.hi_conf
                    else "🟡" if score>=st.session_state.sim_threshold else "🔴")
            with st.expander(
                f"{icon} Match {i} — score {score:.4f} | {doc.metadata.get('sop_ref','?')} | {doc.metadata.get('module','?')}",
                expanded=(i==1)):
                st.text(doc.page_content)
                st.caption(f"Rerun safe: {doc.metadata.get('rerun_safe','?')}")

    # Raw JSON
    with tabs[2 if decision=="L1_FIX_AVAILABLE" else 3]:
        st.markdown("**L1 diagnosis:**"); st.json(l1)
        if st.session_state.l2_filled:
            st.markdown("**L2 pre-fill:**"); st.json(st.session_state.l2_filled)
