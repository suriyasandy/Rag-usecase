def build_l2_query(log: str, l1_answer: str, template_fields: str = "") -> str:
    if template_fields:
        tmpl_section = (
            "Fill EXACTLY these fields from the template (do not add or remove fields):\n"
            + template_fields + "\n\n"
        )
    else:
        tmpl_section = (
            "Include all relevant fields: error summary, affected module, classification, "
            "priority, root cause, what was already tried, stack trace summary, "
            "SOP reference, run ID if visible.\n\n"
        )
    return L2_QUERY.format(
        template_section=tmpl_section,
        l1_answer=l1_answer,
        log=log[:1500],
    )


