# ── OpenAM / SSO Authentication ──────────────────────────────────────────
OPENAM_USERNAME=your_username
OPENAM_PASSWORD=your_password
FQDN=your-host.bank.com
AUTH_URL=https://your-host.bank.com/openam/json/authenticate
JWT_VERSION=v2
VERIFY_TLS=true

# ── LLM endpoint (OpenAI SDK, your custom base_url) ───────────────────────
LLM_BASE_URL=https://your-internal-llm-host/v1
LLM_MODEL=your-llm-model-name
LLM_TEMPERATURE=0.0

# ── Embedding endpoint (same SDK, DIFFERENT base_url + model) ─────────────
EMBED_BASE_URL=https://your-internal-embed-host/v1
EMBED_MODEL=text-embedding-3-small

# ── Local paths ───────────────────────────────────────────────────────────
SOP_CSV_PATH=./sop_data.csv
TEMPLATE_CSV_PATH=./l2_template.csv
FAISS_INDEX_PATH=./poc_faiss_index

# ── Retrieval thresholds ──────────────────────────────────────────────────
SIM_THRESHOLD=0.65
HIGH_CONF_THRESH=0.80
TOP_K=4

# ── CSV column mapping (only needed if your headers differ from defaults) ──
COL_ERROR_PATTERN=error_pattern
COL_ROOT_CAUSE=root_cause
COL_FIX_STEPS=fix_steps
COL_MODULE=module
COL_RERUN_SAFE=rerun_safe
COL_SOP_REF=sop_ref
COL_FIELD_NAME=field_name
COL_DESCRIPTION=description
COL_EXAMPLE=example
COL_MANDATORY=mandatory
